{
  "name": "novabot-server",
  "version": "2026.0614.2147",
  "type": "module",
  "description": "Local Novabot cloud server replacement",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "concurrently -n server,dashboard -c blue,magenta \"tsx watch src/index.ts\" \"npm run dev --prefix ../dashboard\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --noEmitOnError false",
    "build:all": "npm run build && npm run build --prefix ../dashboard",
    "start": "node dist/index.js",
    "lint": "eslint --ext .ts src/",
    "prepare": "cd .. && husky || true"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@stoprocent/noble": "^2.3.16",
    "@types/archiver": "^7.0.0",
    "aedes": "^1.0.0",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^9.4.3",
    "clipper-lib": "^6.4.2",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.15.0",
    "multer": "^2.0.0",
    "multicast-dns": "^7.2.5",
    "node-pty": "^1.0.0",
    "socket.io": "^4.8.3",
    "unzipper": "^0.12.3",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.9",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.0.0",
    "@types/multicast-dns": "^7.2.4",
    "@types/node": "^20.11.30",
    "@types/supertest": "^6.0.3",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@zip.js/zip.js": "^2.8.26",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "supertest": "^7.2.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.3",
    "vitest": "^4.1.4"
  }
}
