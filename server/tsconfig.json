{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "resolvePackageJsonExports": false
  },
  "include": ["src/**/*"],
  // These tests import a pure util from ../../app (outside this project's
  // rootDir) so they can run under the server's vitest — the app has no test
  // runner. tsc would reject the cross-rootDir import; vitest runs them fine
  // and the utils themselves are type-checked by the app's tsc.
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__/utils/mowingMapSelection.test.ts",
    "src/__tests__/utils/mapChannels.test.ts"
  ]
}
