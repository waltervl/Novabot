# EAS Build: only app/ subdirectory is the React Native project.
# All patterns are ROOTED with leading slash so they only match at repo root,
# NOT inside app/ subtree (e.g. app/src/components/mower/ must remain).

# Non-app project directories (root-level only)
/research/
/server/
/dashboard/
/bootstrap/
/firmware/
/mower/
/docs/
/tools/
/data/
/open_node/
/.claude/
/.beads/
/.cache/
/.pytest_cache/
/.superpowers/
/.worktrees/
/.github/
/.husky/
/.vscode/

# Old directory names
/novabot-server/
/novabot-dashboard/
/nova-ota-device/
/open_decision/
/rpi-image/
/setup-wizard/

# App native + dependency dirs (regenerated by EAS)
app/node_modules/
app/ios/
app/android/
app/.expo/
app/dist/
app/web-build/

# Generic build artifacts (rooted dirs only — never inside app/src/)
/build/
/.gradle/

# Root-level DB / state files
/novabot.db
/novabot.db-shm
/novabot.db-wal

# Big binary files (any depth, file extensions only)
*.bin
*.deb
*.elf
*.pklg
*.zip
*.pdf
*.apk
*.aab
*.ipa
*.png.bak

# Secrets (any depth, file extensions only)
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision
*.pem
.env
.env*.local

# OS / editor cruft (file extensions only)
.DS_Store

# Logs
*.log
npm-debug.*
yarn-debug.*
yarn-error.*
