{
  "name": "opennova-installer",
  "version": "0.2.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "build:helper": "node scripts/build-helper.cjs",
    "build": "npm run build:helper && npm run build:main && npm run build:renderer",
    "dev:renderer": "vite",
    "dev": "electron .",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.renderer.json",
    "test": "vitest run",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@fontsource/baloo-2": "^5.2.5",
    "@fontsource/nunito": "^5.2.5",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "drivelist": "^12.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xz-decompress": "^0.2.3"
  }
}
