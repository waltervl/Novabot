{
  "name": "opennova-installer",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dev:renderer": "vite",
    "dev": "electron .",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.renderer.json",
    "test": "vitest run",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "etcher-sdk": "^9.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
