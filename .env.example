# === Novabot Docker Configuration ===
#
# Copy to `.env` and fill in. Every variable referenced by docker-compose.yml
# is listed below — uncomment + set the ones you need.

# === Required ===

# Your server's LAN IP — used for TLS cert SAN, firmware download URLs,
# and any DNS rewrites that point devices at this server.
TARGET_IP=192.168.0.100

# Timezone — must match the timezone the app sends in schedule payloads.
# TZ=Europe/Amsterdam

# === DNS Configuratie ===
# De Novabot app/maaier/charger moeten *.lfibot.com kunnen resolven naar dit IP.
#
# Optie A: Eigen DNS (AdGuard, Pi-hole, router)
#   Zet DISABLE_DNS=true en voeg een DNS rewrite toe in je eigen DNS:
#     *.lfibot.com -> <TARGET_IP>
#
# Optie B: Ingebouwde DNS (dnsmasq in container)
#   Laat DISABLE_DNS op false (default) en stel je router/apparaten DNS in
#   op het IP van deze container.
#
DISABLE_DNS=false
# UPSTREAM_DNS=8.8.8.8
# EXTRA_DOMAINS=example.com

# === TLS / iOS app compatibility ===
# Required for the official Novabot iOS app (it refuses plain HTTP).
# Self-signed cert auto-generated on first start; user installs the
# .mobileconfig profile from /api/setup/profile.
# ENABLE_TLS=true

# === Web dashboard (beta) ===
# ENABLE_DASHBOARD=true

# === Home Assistant MQTT Bridge (optional) ===
# Set HA_MQTT_HOST to enable. The bridge publishes:
#  - one sensor entity per cached field per mower (battery, GPS, errors, …)
#  - a live map image (PNG) entity (requires RENDER_BASE_URL below)
#  - per-event topics novabot/events/<SN> + novabot/events/<SN>/<event_type>
HA_MQTT_HOST=192.168.0.248
HA_MQTT_PORT=1883
HA_MQTT_USER=mqtt
HA_MQTT_PASS=mqtt
# HA_DISCOVERY_PREFIX=homeassistant       # rarely changed
# HA_THROTTLE_MS=2000                     # min ms between sensor republishes per mower

# Public URL HA uses to fetch the rendered map PNG. Required for the
# image entity — leave unset and only sensor entities appear.
RENDER_BASE_URL=http://192.168.0.222

# Min ms between map-image URL republishes (forces HA to refetch).
HA_MAP_THROTTLE_MS=15000

# Optional: HA webhook trigger URL — full event JSON POSTed on every
# detected event (mowing_started, stuck, safety, …).
# HA_WEBHOOK_URL=http://homeassistant.local:8123/api/webhook/novabot_events

# === ntfy.sh Push Notifications (optional, free, no account) ===
# Pick a long random topic — public ntfy topics are unauthenticated, so
# anyone subscribed to the topic can read your events.
# Install the ntfy app (App Store / Play Store) and subscribe to the
# same topic to receive notifications on your phone.
NTFY_TOPIC=novabot-rvb-x7k9q
NTFY_URL=https://ntfy.sh
NTFY_PRIORITY=4                           # 1..5, optional; bump for noisier alerts

# === Notification tuning ===
# Battery % crossing point for the low_battery event (fires once per dip
# below the threshold; resets when battery climbs back above).
LOW_BATTERY_THRESHOLD=20

# Topic prefix for the local MQTT event publishes that HA's MQTT
# integration auto-discovers. Rarely changed.
# EVENTS_MQTT_TOPIC_PREFIX=novabot/events

# === OTA / firmware ===
# Override the path inside the container where firmware images are stored.
# FIRMWARE_PATH=/data/firmware

# === Debug ===
# Log every successful JWT auth (verbose; useful for tracing token churn).
# AUTH_DEBUG=1
