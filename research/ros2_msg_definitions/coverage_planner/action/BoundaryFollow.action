#2 - result definition
uint8 LOOP_CLOSED=0
uint8 NO_VALID_BOUNDARY=1
uint8 CANCELLED=2
uint8 FOLLOW_FAILED=3
uint8 SEARCHING_START_FAILED=4
uint8 TF_RELATED_EXCEPTION=5
uint8 NAV_TO_POSE_ACTION_EXCEPTION=6
uint8 status
string msg
