research/coverage-native/build*/
research/coverage-native/eth/.git/
/tmp
AUTONOMOUS-MAPPING.md

# IDE / OS
.vscode
.idea
*.swp
.DS_Store

# Existing DNS container (now integrated)
novabot-dns/
